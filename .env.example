# PAYSTACK_SECRET_KEY=sk_live_...
# PAYSTACK_WEBHOOK_SECRET=your-webhook-secret
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_...

# App
NEXT_PUBLIC_APP_URL=https://main.dbml7dywatb8x.amplifyapp.com
