# Supabase — create a NEW project at supabase.com for LeadCard (separate from HPS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Resend — https://resend.com (can reuse HPS key or create new)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@leadcard.app

# PayFast — https://www.payfast.co.za (add in session 3)
# PAYFAST_MERCHANT_ID=your-merchant-id
# PAYFAST_MERCHANT_KEY=your-merchant-key
# PAYFAST_PASSPHRASE=your-passphrase
# NEXT_PUBLIC_PAYFAST_MERCHANT_ID=your-merchant-id

# App
NEXT_PUBLIC_APP_URL=https://main.dbml7dywatb8x.amplifyapp.com
